{
    email {$ACME_EMAIL}
}

# ============================================================
# Public authentication domain
# Redirects / to the product site. Proxies realm endpoints to Keycloak.
# Admin console UI is BLOCKED here — use the admin subdomain.
#
# NOTE: master realm endpoints are intentionally NOT blocked here.
# Keycloak's admin console (on auth-admin) uses the main KC_HOSTNAME
# for its own OIDC auth flow — so auth-admin redirects the browser to
# auth.starkyapp.com/realms/master/protocol/openid-connect/auth to log in.
# Blocking /realms/master/* here breaks that flow with "Something went wrong".
# Admin UI access is still guarded by the /admin/* block + IP allow-list
# on the admin hostname.
# ============================================================
{$AUTH_HOSTNAME} {
    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' data: https://fonts.gstatic.com; frame-src 'self'; frame-ancestors 'self'; form-action 'self' https:;"
        -Server
    }

    # Caddy-local health endpoint (doesn't hit Keycloak)
    @health path /health
    handle @health {
        respond "healthy" 200
    }

    # Root → product site
    @root path /
    redir @root https://starkyapp.com 302

    # Block admin console on the public domain
    @admin path /admin /admin/*
    handle @admin {
        respond "Admin access is not permitted on this domain. Use the admin subdomain." 403
    }

    # Everything else → Keycloak
    handle {
        reverse_proxy keycloak:8080
    }
}

# ============================================================
# Admin console — IP-restricted
# ADMIN_ALLOWED_IPS is a space-separated list of IPs/CIDRs.
# Default (127.0.0.1/32) denies every real client.
# ============================================================
{$ADMIN_HOSTNAME} {
    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @allowed remote_ip {$ADMIN_ALLOWED_IPS}
    handle @allowed {
        reverse_proxy keycloak:8080
    }

    handle {
        respond "Access denied. Your IP is not in the admin allow-list." 403
    }
}
