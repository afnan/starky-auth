# ============================================
# Keycloak Production Environment
# ============================================
# Copy this file to .env and set real values.
# NEVER commit .env to version control.

# ============================================
# Domains (BARE hostnames — no scheme, no trailing slash)
# ============================================
AUTH_HOSTNAME=auth.allspicetech.com.au
ADMIN_HOSTNAME=auth-admin.allspicetech.com.au

# ============================================
# TLS / ACME (Let's Encrypt via Caddy)
# ============================================
# Email used by Let's Encrypt for expiry notices and account recovery.
ACME_EMAIL=ops@allspicetech.com.au

# ============================================
# Admin console IP allow-list
# Space-separated list of IPs or CIDRs allowed to reach the admin subdomain.
# Default (127.0.0.1/32) denies every real client — set this before going live.
# Find your IP: curl ifconfig.me
# Example: ADMIN_ALLOWED_IPS=203.0.113.10/32 10.0.0.0/8
# ============================================
ADMIN_ALLOWED_IPS=127.0.0.1/32

# ============================================
# Keycloak
# ============================================
# Latest stable: https://github.com/keycloak/keycloak/releases
KEYCLOAK_VERSION=26.1

# Admin credentials — CHANGE BEFORE FIRST BOOT
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_IN_PRODUCTION

# Feature flags (comma-separated)
KEYCLOAK_FEATURES=token-exchange,admin-fine-grained-authz

# Logging
KEYCLOAK_LOG_LEVEL=INFO
KEYCLOAK_ROOT_LOG_LEVEL=INFO

# Theme caching — set to false only during theme development
KC_THEME_CACHING=true

# ============================================
# PostgreSQL
# ============================================
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak_db_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ============================================
# Host ports (only change if 80/443 are taken on the host)
# ============================================
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# Notes
# ============================================
# 1. Generate strong passwords: openssl rand -base64 32
# 2. Point AUTH_HOSTNAME and ADMIN_HOSTNAME at this server's public IP
#    BEFORE first boot. Caddy requests certificates on first request.
# 3. Port 80 must be reachable from the internet for ACME challenges.
# 4. Schedule backup.sh via cron; test restore procedures periodically.
