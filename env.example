# ============================================
# Starky Central Auth — Environment
# ============================================
# Copy this file to .env on the VM and set real values.
# NEVER commit .env to version control.
#
# In CI/CD, the actual .env on the VM is written by the GitHub Actions
# pipeline from the VM_ENV_FILE repo secret. This file is the schema /
# documentation reference.

# ============================================
# Domains (BARE hostnames — no scheme, no trailing slash)
# ============================================
AUTH_HOSTNAME=auth.starkyapp.com
ADMIN_HOSTNAME=auth-admin.starkyapp.com

# ============================================
# TLS / ACME (Let's Encrypt via Caddy)
# ============================================
ACME_EMAIL=accounts@allspicetech.com.au

# ============================================
# Admin console IP allow-list
# Space-separated list of IPs or CIDRs allowed to reach the admin subdomain.
# Default (127.0.0.1/32) denies every real client — set this before going live.
# Find your IP: curl ifconfig.me
# ============================================
ADMIN_ALLOWED_IPS=127.0.0.1/32

# ============================================
# Keycloak
# ============================================
# Admin credentials — CHANGE BEFORE FIRST BOOT
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_IN_PRODUCTION

# Logging
KEYCLOAK_LOG_LEVEL=INFO
KEYCLOAK_ROOT_LOG_LEVEL=INFO

# Theme caching — set to false only during theme development
KC_THEME_CACHING=true

# ============================================
# PostgreSQL
# ============================================
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak_db_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ============================================
# Host ports
# ============================================
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# Deploy image tag
# Overridden per-deploy by the Actions pipeline. `latest` is the safe default
# on a fresh VM; pipeline writes back a pinned SHA on each successful deploy.
# ============================================
IMAGE=starkyacr.azurecr.io/starky-auth:latest

# ============================================
# Notes
# ============================================
# 1. Generate strong passwords: openssl rand -base64 32
# 2. DNS A records for AUTH_HOSTNAME + ADMIN_HOSTNAME must point to the Azure
#    static public IP BEFORE first boot. Caddy requests certificates on first
#    request.
# 3. Port 80 must be reachable from the internet for ACME challenges (NSG rule 100).
